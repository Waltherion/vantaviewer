{
  // vantaviewer keybindings. Copied to ~/.config/vantaviewer/keybindings.jsonc on
  // first run; edit that file (this one in the repo is just the reference default).
  //
  // Each action maps to one chord or a list of chords. A chord is e.g. "f", "Right",
  // "Ctrl+S", "[", or any single key (including non-ASCII layout keys).
  // Defaults below follow US-layout key positions; remap freely, e.g.
  //   "rotateCCW": "e",  "rotateCW": "t"

  "next":          ["Right", "space"],
  "prev":          "Left",
  "fit":           ["0", "="],
  "oneToOne":      "1",
  "rotateCW":      "]",
  "rotateCCW":     "[",
  "rotate180":     "r",
  "exposureUp":    ".",
  "exposureDown":  ",",
  "exposureReset": "/",
  "crop":          "c",
  "cropRatio":     "x",
  "cropRatioPrev": "z",
  "save":          "Ctrl+S",
  "saveAs":        "Ctrl+Shift+S",
  "info":          "i",
  "fullscreen":    "f",
  "quit":          ["q", "Escape"]
}
